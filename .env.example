RAGPLATFORM_ENVIRONMENT=local
RAGPLATFORM_ROUTER_CONFIDENCE_THRESHOLD=0.75
RAGPLATFORM_DEFAULT_TOP_K=5
RAGPLATFORM_MAX_CHUNKS_PER_CORPUS=5000
RAGPLATFORM_MAX_QUERY_LATENCY_SECONDS=5.0

