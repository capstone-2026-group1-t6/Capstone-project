RAGPLATFORM_ENVIRONMENT=local
RAGPLATFORM_ROUTER_CONFIDENCE_THRESHOLD=0.6
RAGPLATFORM_DEFAULT_TOP_K=5
RAGPLATFORM_MAX_CHUNKS_PER_CORPUS=5000
RAGPLATFORM_MAX_QUERY_LATENCY_SECONDS=5.0

# LLM — OpenAI-compatible client (see app/services/llm_client.py)
#
# Recommended free + fast for full eval (Cerebras — no Google billing):
RAGPLATFORM_LLM_API_BASE=https://api.cerebras.ai/v1
RAGPLATFORM_LLM_MODEL=gpt-oss-120b
RAGPLATFORM_LLM_API_KEY=
#
# Alternatives:
# Groq (default if base empty; free TPM is tight for full eval):
#   RAGPLATFORM_LLM_API_BASE=https://api.groq.com/openai/v1
#   RAGPLATFORM_LLM_MODEL=llama-3.1-8b-instant
# Gemini (may require billing setup):
#   RAGPLATFORM_LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/
#   RAGPLATFORM_LLM_MODEL=gemini-2.0-flash


# Neo4j — set password to empty string to disable graph retrieval entirely
RAGPLATFORM_GRAPH_DB_URI=bolt://localhost:7687
RAGPLATFORM_GRAPH_DB_USER=neo4j
RAGPLATFORM_GRAPH_DB_PASSWORD=
RAGPLATFORM_GRAPH_DB_DATABASE=neo4j
