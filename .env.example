RAGPLATFORM_ENVIRONMENT=local
RAGPLATFORM_ROUTER_CONFIDENCE_THRESHOLD=0.75
RAGPLATFORM_DEFAULT_TOP_K=5
RAGPLATFORM_MAX_CHUNKS_PER_CORPUS=5000
RAGPLATFORM_MAX_QUERY_LATENCY_SECONDS=5.0

# Leave blank locally; set in host env for the deployed target (never commit real keys)
RAGPLATFORM_LLM_API_BASE=
RAGPLATFORM_LLM_API_KEY=

# Neo4j — set password to empty string to disable graph retrieval entirely
RAGPLATFORM_GRAPH_DB_URI=bolt://localhost:7687
RAGPLATFORM_GRAPH_DB_USER=neo4j
RAGPLATFORM_GRAPH_DB_PASSWORD=
RAGPLATFORM_GRAPH_DB_DATABASE=neo4j
